# ============================================================
# TBM (Tap Beat Machine) — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── App ─────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── LLM Provider Selection ──────────────────────────────────
# Which AI provider to use: gemini | openai | anthropic | grok | deepseek | ollama
# If not set, auto-detects based on which API keys are configured.
# LLM_PROVIDER=gemini

# ── Google Gemini ───────────────────────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── OpenAI ──────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic (Claude) ──────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── xAI (Grok) ─────────────────────────────────────────────
# https://console.x.ai/
GROK_API_KEY=

# ── DeepSeek ────────────────────────────────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── Ollama (Local) ──────────────────────────────────────────
# No API key needed — just have Ollama running locally.
# Default: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# ── Model Overrides (optional) ──────────────────────────────
# Override the default model for each provider.
# LLM_MODEL_GEMINI=gemini-2.0-flash
# LLM_MODEL_OPENAI=gpt-4o-mini
# LLM_MODEL_ANTHROPIC=claude-sonnet-4-20250514
# LLM_MODEL_GROK=grok-3-mini-fast
# LLM_MODEL_DEEPSEEK=deepseek-chat
# LLM_MODEL_OLLAMA=llama3
