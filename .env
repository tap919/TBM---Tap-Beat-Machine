# ============================================================
# TBM (Tap Beat Machine) — Environment Configuration
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── LLM Provider Selection ──────────────────────────────────
LLM_PROVIDER=deepseek

# ── Google Gemini ───────────────────────────────────────────
GEMINI_API_KEY=

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=

# ── xAI (Grok) ─────────────────────────────────────────────
GROK_API_KEY=

# ── DeepSeek ────────────────────────────────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

